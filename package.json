{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names api,vite --prefix-colors blue,green \"npm:dev:api\" \"npm:dev:client\"",
    "dev:api": "tsx server.ts",
    "dev:client": "vite",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "build": "vite build && node esbuild.server.mjs",
    "preview": "vite preview",
    "clean": "npx rimraf dist",
    "analyze": "cross-env ANALYZE=1 vite build && node esbuild.server.mjs",
    "lint": "tsc --noEmit"
  },
